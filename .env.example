# Supabase Configuration
# Get these from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Twilio SMS Configuration (Optional - for milestone notifications)
# Sign up at https://www.twilio.com and get your credentials
# See SMS_SETUP.md for detailed setup instructions

EXPO_PUBLIC_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_auth_token_here
EXPO_PUBLIC_TWILIO_PHONE_NUMBER=+1234567890
